BOT_TOKEN=your_discord_bot_token
# Optional. Used by command cleanup scripts; auto-detected when omitted.
DISCORD_CLIENT_ID=your_discord_application_id
# Optional. Comma-separated server IDs for immediate guild command sync.
DISCORD_GUILD_IDS=your_discord_server_id
# Optional. Defaults to mistral-small-latest.
MISTRAL_MODEL=mistral-small-latest
# Optional. Recent channel messages included when Missy is mentioned.
DISCORD_CONTEXT_MESSAGES=20
# Required for /mcp-add. Comma-separated Discord user IDs.
MCP_ADMIN_USER_IDS=your_discord_user_id
