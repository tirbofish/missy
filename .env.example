BOT_TOKEN=your_discord_bot_token
# Optional. Used by command cleanup scripts; auto-detected when omitted.
DISCORD_CLIENT_ID=your_discord_application_id
# Optional. Comma-separated server IDs for immediate guild command sync.
DISCORD_GUILD_IDS=your_discord_server_id
# Optional. Defaults to 0 when DISCORD_GUILD_IDS is set to avoid duplicate
# guild-visible slash commands. Set to 1 only if you intentionally want global
# slash commands too.
DISCORD_REGISTER_GLOBAL_COMMANDS=0
# Optional. Defaults to mistral-small-latest.
MISTRAL_MODEL=mistral-small-latest
# Optional. Defaults to 1. Uses Mistral Conversations API with built-in web_search.
MISTRAL_ENABLE_WEBSEARCH=1
# Optional. Use web_search or web_search_premium.
MISTRAL_WEBSEARCH_TOOL=web_search
# Optional. Defaults to deleting transient Conversations API threads after use.
MISTRAL_KEEP_CONVERSATIONS=0
# Optional. Recent channel messages included when Missy is mentioned.
DISCORD_CONTEXT_MESSAGES=20
# Required for /mcp-add. Comma-separated Discord user IDs.
MCP_ADMIN_USER_IDS=your_discord_user_id
# Optional. Comma-separated Discord role IDs that can use /mcp-add.
MCP_ADMIN_ROLE_IDS=your_discord_role_id
# Optional. Comma-separated Discord user IDs allowed to use local Desktop,
# computer, and filesystem tools. Defaults to no one.
MISSY_LOCAL_ACCESS_USER_IDS=your_discord_user_id
# Optional. Comma-separated Discord role IDs allowed to use local Desktop,
# computer, and filesystem tools.
MISSY_LOCAL_ACCESS_ROLE_IDS=your_discord_role_id
# Optional. Comma-separated Discord user IDs allowed to stop the bot with
# /shutdown. Defaults to no one.
MISSY_SHUTDOWN_USER_IDS=your_discord_user_id
# Optional. Comma-separated Discord role IDs allowed to stop the bot with
# /shutdown.
MISSY_SHUTDOWN_ROLE_IDS=your_discord_role_id

# Required for scripts/mcp/agent-sdk-google-computer.ts.
OPENAI_API_KEY=your_openai_api_key
# Optional. Defaults to gpt-5.4.
MISSY_AGENT_MODEL=gpt-5.4
# Optional. One token can be reused for all Google connectors, or use
# service-specific values below.
GOOGLE_CONNECTOR_AUTHORIZATION=your_google_oauth_access_token
GOOGLE_DRIVE_AUTHORIZATION=your_google_drive_oauth_access_token
GMAIL_AUTHORIZATION=your_gmail_oauth_access_token
GOOGLE_CALENDAR_AUTHORIZATION=your_google_calendar_oauth_access_token
# Optional. Set to 1 to enable the local read-only computer shell tool.
MISSY_AGENT_ENABLE_COMPUTER=0
# Optional. Defaults to the current working directory.
MISSY_AGENT_COMPUTER_ROOT=T:\missy
# Optional. Defaults to %USERPROFILE%\Desktop.
MISSY_DESKTOP_ROOT=C:\Users\you\Desktop
