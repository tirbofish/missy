{
  "tasks": {
    "dev": "deno run -E -R --allow-write --allow-run -N --env-file=.env --watch src/main.ts",
    "check": "deno check --allow-import src/main.ts src/commands/missy.ts scripts/commands.ts scripts/mcp/agent-sdk-google-computer.ts",
    "commands:clear-global": "deno run -E -N --env-file=.env scripts/commands.ts clear-global",
    "commands:clear-guilds": "deno run -E -N --env-file=.env scripts/commands.ts clear-guilds",
    "commands:clear-all": "deno run -E -N --env-file=.env scripts/commands.ts clear-all",
    "mcp:agent-sdk": "deno run -E -R --allow-run=powershell --allow-net=api.openai.com scripts/mcp/agent-sdk-google-computer.ts"
  },
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true
  },
  "imports": {
    "@discordx/importer": "npm:@discordx/importer@^1.3.3",
    "@std/assert": "jsr:@std/assert@1",
    "discord.js": "npm:discord.js@^14.26.4",
    "discordx": "npm:discordx@^11.13.3"
  }
}
