{
  "nodeModulesDir": "auto",
  "tasks": {
    "setup": "bun bin/dev.js interactive",
    "dev": "bun --watch bootstrap.ts start",
    "start": "bun bootstrap.ts start",
    "check": "tsc --noEmit",
    "test": "bun test"
  },
  "imports": {
    "@mistralai/mistralai": "npm:@mistralai/mistralai@^2.2.0",
    "openai": "npm:openai@^4.96.0",
    "discord.js": "npm:discord.js@^14.22.1",
    "matrix-bot-sdk": "npm:matrix-bot-sdk@^0.8.0",
    "@matrix-org/matrix-sdk-crypto-nodejs": "npm:@matrix-org/matrix-sdk-crypto-nodejs@^0.4.0",
    "@session.js/client": "npm:@session.js/client@^0.0.57",
    "@session.js/types": "npm:@session.js/types@^1.0.19",
    "@session.js/mnemonic": "npm:@session.js/mnemonic@^1.0.6"
  },
  "allowScripts": {
    "allow": ["npm:@matrix-org/matrix-sdk-crypto-nodejs@0.4.0"],
    "deny": ["npm:esbuild@0.28.0"]
  }
