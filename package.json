{
  "name": "missy",
  "version": "1.0.0",
  "description": "Missy AI Agent CLI",
  "type": "module",
  "bin": {
    "missy": "./bin/run.js"
  },
  "oclif": {
    "bin": "missy",
    "dirname": "missy",
    "commands": "./cli/commands",
    "default": "interactive",
    "topicSeparator": " "
  },
  "scripts": {
    "build": "tsc -p tsconfig.cli.json",
    "dev": "node --loader tsx bin/dev.js",
    "start": "node bin/run.js"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@oclif/core": "^4.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
